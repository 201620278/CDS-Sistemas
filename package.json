{
  "name": "mercadao-da-economia",
  "version": "1.0.3",
  "description": "Sistema de gestão para mercado",
  "author": "CDS Sistemas",
  "main": "electron.js",
  "scripts": {
    "start": ".\\node_modules\\electron\\dist\\electron.exe .\\electron.js",
    "server": "node backend/server.js",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.4",
    "sqlite3": "^5.1.6",
    "xml-crypto": "^6.1.2",
    "xml2js": "^0.5.0"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "25.1.8",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.cd.sistemas",
    "productName": "Esquinão da Economia",
    "directories": {
      "output": "dist-ia32"
    },
    "asar": false,
    "files": [
      "backend/**/*",
      "frontend/**/*",
      "storage/**/*",
      "electron.js",
      "preload.js",
      "package.json",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Esquinão da Economia",
      "artifactName": "Esquinão-da-Economia-Setup-${version}-ia32.exe"
    }
  }
}
